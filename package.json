{
  "name": "ai-app-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI app builder with chat-first interface",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @ai-app-builder/web dev",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' build",
    "test": "pnpm --filter './packages/**' test && pnpm --filter './apps/**' test",
    "lint": "pnpm --filter './packages/**' lint && pnpm --filter './apps/**' lint",
    "typecheck": "pnpm --filter './packages/**' typecheck && pnpm --filter './apps/**' typecheck",
    "clean": "rm -rf node_modules **/node_modules **/dist **/.next"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
